++                    Boolean existing = mergedRules.get(pkg);
++
++                    if (denied) {
++                        if (existing == null || existing == true ) { // New entry with deny, or change existing allow to deny
++                            mergedRules.put(pkg, true); // Aseguramos el paquete original
++
++                            if (groupSticky) { // Forzamos el bloqueo para todos los paquetes del UID
++                                PackageStateInternal targetPs = snapshot.getPackageStateInternal(pkg);
++                                if (targetPs == null) {
++                                    String baseName = getBasePackageName(pkg);
++                                    if (baseName != null) {
++                                        targetPs = snapshot.getPackageStateInternal(baseName);
++                                    }
++                                }
++                                if (targetPs != null) {
++                                    int targetAppId = targetPs.getAppId();
