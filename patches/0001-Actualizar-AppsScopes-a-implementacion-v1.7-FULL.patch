++    @Nullable
++    private static String getBasePackageName(@Nullable String pkgName) {
++        if (pkgName == null) return null;
++
++        int end = 0;
++        boolean isSubstring = false;
++        while (end < pkgName.length()) {
++            char c = pkgName.charAt(end);
++
++            if (!Character.isLetterOrDigit(c) && c != '.' && c != '_') {
++                break;
++            }
++            end++;
++        }
++        if ( end > 0 ) {
++            pkgName = pkgName.substring(0, end);
++            isSubstring = true;
++        }
++
++        int lastUnderscore = pkgName.lastIndexOf('_');
++        if (lastUnderscore > 0 && lastUnderscore < pkgName.length() - 1) {
++            String suffix = pkgName.substring(lastUnderscore + 1);
++            boolean isNumeric = true;
++            for (int i = 0; i < suffix.length(); i++) {
++                if (!Character.isDigit(suffix.charAt(i))) {
++                    isNumeric = false;
++                    break;
++                }
++            }
++            if (isNumeric) {
++                return pkgName.substring(0, lastUnderscore);
++            }
++        }
++
++        if (isSubstring) {
++            return pkgName;
++        }
++        return null;
++    }
