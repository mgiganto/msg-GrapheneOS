++            // Rule 3: Merge specific rules with DENY priority over allow
++            if (config.specificRules != null) {
++                for (Map.Entry<String, Boolean> entry : config.specificRules.entrySet()) {
++                    String pkg = entry.getKey();
++                    boolean denied = !entry.getValue(); //getValue returns isAllow, so we negate it to get deny
