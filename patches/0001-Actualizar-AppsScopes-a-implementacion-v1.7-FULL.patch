++                                    if (targetPair != null && targetPair.second != null) {
++                                        // Es un Shared UID: bloqueamos a todos los miembros
++                                        for (PackageStateInternal p : targetPair.second.getPackageStates()) {
++                                            mergedRules.put(p.getPackageName(), true);
