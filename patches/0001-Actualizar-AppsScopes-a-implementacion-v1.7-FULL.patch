++/**
++ * Configuration for Apps Scope, which controls the visibility of other apps.
++ * @hide
++ */
++public final class AppsScope implements Parcelable {
++    private static final String TAG = "AppsScope";
++
++    public static final int FLAG_RESTRICT_SELF = 1;
++    public static final int FLAG_RESTRICT_SHARED_CERT = 1 << 1;
++    public static final int FLAG_RESTRICT_SYSTEM = 1 << 2;
++    public static final int FLAG_RESTRICT_QUERIES = 1 << 3;
++
++    public final int flags;
++    @NonNull
++    public final Map<String, Boolean> specificRules;
++
++    public AppsScope(int flags, @NonNull Map<String, Boolean> specificRules) {
++        this.flags = flags;
++        ArrayMap<String, Boolean> map = new ArrayMap<>(specificRules.size());
++        map.putAll(specificRules);
++        this.specificRules = Collections.unmodifiableMap(map);
++    }
++
++    public boolean isDefault() {
++        return flags == 0 && specificRules.isEmpty();
++    }
++
++    private AppsScope(Parcel in) {
++        flags = in.readInt();
++        int size = in.readInt();
++        ArrayMap<String, Boolean> map = new ArrayMap<>(size);
++        for (int i = 0; i < size; i++) {
++            map.put(in.readString(), in.readBoolean());
++        }
++        specificRules = Collections.unmodifiableMap(map);
++    }
++
++    @Override
++    public void writeToParcel(@NonNull Parcel dest, int parcelFlags) {
++        dest.writeInt(this.flags);
++        dest.writeInt(specificRules.size());
++        for (Map.Entry<String, Boolean> entry : specificRules.entrySet()) {
++            dest.writeString(entry.getKey());
++            dest.writeBoolean(entry.getValue());
++        }
++    }
++
++    @Override
++    public int describeContents() {
++        return 0;
++    }
++
++    public static final @NonNull Creator<AppsScope> CREATOR = new Creator<AppsScope>() {
++        @Override
++        public AppsScope createFromParcel(Parcel in) {
++            return new AppsScope(in);
++        }
++
++        @Override
++        public AppsScope[] newArray(int size) {
++            return new AppsScope[size];
++        }
++    };
++
++    private static final int VERSION = 1;
++
++    @NonNull
++    public static Intent createConfigActivityIntent(@NonNull String packageName) {
++        Intent intent = new Intent("android.settings.APPS_SCOPE_DETAILS");
++        intent.setData(Uri.parse("package:" + packageName));
++        return intent;
++    }
++
++    @Nullable
++    public static byte[] serialize(@Nullable AppsScope config) {
++        if (config == null) {
++            return null;
++        }
++
++        try {
++            JSONObject json = new JSONObject();
++            json.put("restrictSelf", (config.flags & FLAG_RESTRICT_SELF) != 0);
++            json.put("restrictSharedCert", (config.flags & FLAG_RESTRICT_SHARED_CERT) != 0);
++            json.put("restrictSystem", (config.flags & FLAG_RESTRICT_SYSTEM) != 0);
++            json.put("restrictQueries", (config.flags & FLAG_RESTRICT_QUERIES) != 0);
++
++            JSONObject specificRules = new JSONObject();
++            for (Map.Entry<String, Boolean> entry : config.specificRules.entrySet()) {
++                specificRules.put(entry.getKey(), entry.getValue());
++            }
++            json.put("specificRules", specificRules);
++
++            return json.toString(2).getBytes(StandardCharsets.UTF_8);
++        } catch (JSONException e) {
++            Slog.e(TAG, "serialization failed", e);
++            return null;
++        }
++    }
++
++    @Nullable
++    public static AppsScope deserialize(@Nullable byte[] data) {
++        if (data == null) {
++            return null;
++        }
++
++        try {
++            String str = new String(data, StandardCharsets.UTF_8);
++            JSONObject json = new JSONObject(str);
++
++            int flags = 0;
++            if (json.optBoolean("restrictSelf", false)) flags |= FLAG_RESTRICT_SELF;
++            if (json.optBoolean("restrictSharedCert", false)) flags |= FLAG_RESTRICT_SHARED_CERT;
++            if (json.optBoolean("restrictSystem", false)) flags |= FLAG_RESTRICT_SYSTEM;
++            if (json.optBoolean("restrictQueries", false)) flags |= FLAG_RESTRICT_QUERIES;
++
++            ArrayMap<String, Boolean> specificRules = new ArrayMap<>();
++            JSONObject rulesObj = json.optJSONObject("specificRules");
++            if (rulesObj != null) {
++                Iterator<String> keys = rulesObj.keys();
++                while (keys.hasNext()) {
++                    String pkg = keys.next();
++                    specificRules.put(pkg, rulesObj.optBoolean(pkg, true));
++                }
++            }
++
++            return new AppsScope(flags, specificRules);
++        } catch (JSONException e) {
++            Slog.e(TAG, "deserialization failed", e);
++            return null;
++        }
++    }
++
++    /** @hide */
++    public static class Builder {
++        private int flags;
++        private final ArrayMap<String, Boolean> specificRules;
++
++        public Builder() {
++            this.flags = 0;
++            this.specificRules = new ArrayMap<>();
++        }
++
++        public Builder(AppsScope config) {
++            this.flags = config.flags;
++            this.specificRules = new ArrayMap<>();
++            this.specificRules.putAll(config.specificRules);
++        }
++
++        @NonNull
++        public static Builder from(@Nullable AppsScope config) {
++            return config != null ? new Builder(config) : new Builder();
++        }
++
++        public Builder setFlags(int flags) {
++            this.flags = flags;
++            return this;
++        }
++
++        public Builder addFlag(int flag) {
++            this.flags |= flag;
++            return this;
++        }
++
++        public Builder clearFlag(int flag) {
++            this.flags &= ~flag;
++            return this;
++        }
++
++        public Builder addPackage(String pkg, boolean allowed) {
++            specificRules.put(pkg, allowed);
++            return this;
++        }
++
++        public Builder removePackage(String pkg) {
++            specificRules.remove(pkg);
++            return this;
++        }
++
++        public AppsScope build() {
++            return new AppsScope(flags, specificRules);
++        }
++    }
++
++    /**
++     * Filters a delimiter-separated component list (e.g. "pkg/cls:pkg2/cls2") by removing
++     * components whose package is hidden from the caller by AppsScope rules.
++     *
++     * This implementation is optimized to resolve the caller context only once and use
++     * a HashSet for O(1) lookups during filtering.
++     *
++     * @param componentList raw delimited string (may be null/empty)
++     * @param delimiter     the delimiter character (e.g. ':' or ';')
++     * @param callingUid    UID of caller requesting the setting
++     * @param userId        user ID
++     * @return filtered string, or null if the result would be empty
++     *
++     * @hide
++     */
++    public static @Nullable String filterComponentList(@Nullable String componentList,
++            char delimiter, int callingUid, int userId) {
++        return filterComponentList(componentList, delimiter, callingUid, userId, true /* groupSticky */);
++    }
++
++    public static @Nullable String filterComponentList(@Nullable String componentList,
++            char delimiter, int callingUid, int userId, boolean groupSticky) {
++        if (componentList == null || componentList.isEmpty()) {
++            return componentList;
++        }
++
++        // Fast path for SYSTEM and root
++        if (callingUid == Process.SYSTEM_UID || callingUid == 0) {
++            return componentList;
++        }
++
++        IPackageManager pm = AppGlobals.getPackageManager();
++        if (pm == null) {
++            return componentList;
++        }
++
++        try {
++            String[] components = componentList.split(Pattern.quote(String.valueOf(delimiter)), -1);
++            StringBuilder sb = new StringBuilder();
++            String delim = String.valueOf(delimiter);
++
++            // Fetch destination app once to optimize? No, we filter multiple target apps.
++            // We need the GosPackageState of the CALLER (source) to get its AppsScope rules.
++            String[] packages = pm.getPackagesForUid(callingUid);
++            if (packages == null || packages.length == 0) return componentList;
++            String callingPkg = packages[0];
++            GosPackageState callingGosState = pm.getGosPackageState(callingPkg, userId);
++
++            if (callingGosState == null || !callingGosState.hasFlag(GosPackageStateFlag.APPS_SCOPES_ENABLED)) {
++                return componentList;
++            }
++
++            AppsScope scope = callingGosState.getAppsScope();
++            for (String component : components) {
++                int dotIdx = component.indexOf('.');
++
++                while (dotIdx != -1) {
++                    // 1. Expand left (find the start of the island)
++                    int start = dotIdx;
++                    while (start > 0) {
++                        char c = component.charAt(start - 1);
++                        if (!((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') ||
++                              (c >= '0' && c <= '9') || c == '_' || c == '.')) {
++                            break;
++                        }
++                        start--;
++                    }
++
++                    // 2. Expand right (find the end of the island)
++                    int end = dotIdx;
++                    while (end < component.length()) {
++                        char c = component.charAt(end);
++                        if (!((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') ||
++                              (c >= '0' && c <= '9') || c == '_' || c == '.')) {
++                            break;
++                        }
++                        end++;
++                    }
++
++                    // 3. Extract candidate
++                    String candidatePkg = component.substring(start, end);
++
++                    // 4. Official Framework Validation
++                    // requireSeparator=true ensures it has a dot, requireModifier=true follows naming rules
++                    String error = FrameworkParsingPackageUtils.validateName(candidatePkg, true, true);
++
++                    if (error == null && !shouldAllowVisibility(pm, scope, callingUid, callingPkg, candidatePkg, userId, groupSticky)) {
++                        Slog.i(TAG, "Sensitive component hidden via AppsScope: [" + candidatePkg + "] for UID " + callingUid + " located in string [" + component + "]");
++                        break;
++                    }
++
++                    // 5. Fast-Forward to next dot after this island
++                    dotIdx = component.indexOf('.', end);
++                }
++
++                if (dotIdx == -1) { // We reach end of string scan and no restriction found on it. Append it to the result.
++                    if (sb.length() > 0) sb.append(delim);
++                    sb.append(component);
++                }
++            }
++
++            return sb.length() > 0 ? sb.toString() : null;
++        } catch (RemoteException e) {
++            return componentList;
++        }
++    }
++
++    /**
++     * Checks if the caller is allowed to see the target package based on AppsScope rules.
++     * This method handles the logic for determining visibility.
++     *
++     * @param callingUid UID of the caller
++     * @param targetPkg  Package name of the target to check
++     * @param userId     User ID
++     * @return true if visibility is allowed, false otherwise
++     *
++     * @hide
++     */
++    public static boolean shouldAllowVisibility(int callingUid, @Nullable String targetPkg, int userId) {
++        return shouldAllowVisibility(callingUid, targetPkg, userId, true /* groupSticky */);
++    }
++
++    public static boolean shouldAllowVisibility(int callingUid, @Nullable String targetPkg, int userId, boolean groupSticky) {
++        if (targetPkg == null || targetPkg.isEmpty()) {
++            return true;
++        }
++
++        // Fast path for SYSTEM and root
++        if (callingUid == Process.SYSTEM_UID || callingUid == 0) {
++            return true;
++        }
++
++        IPackageManager pm = AppGlobals.getPackageManager();
++        if (pm == null) {
++            return true;
++        }
++
++        try {
++            String[] packages = pm.getPackagesForUid(callingUid);
++            if (packages == null || packages.length == 0) return true;
++            String callingPkg = packages[0];
++
++            GosPackageState callingGosState = pm.getGosPackageState(callingPkg, userId);
++            if (callingGosState == null || !callingGosState.hasFlag(GosPackageStateFlag.APPS_SCOPES_ENABLED)) {
++                return true;
++            }
++
++            AppsScope scope = callingGosState.getAppsScope();
++
++            return shouldAllowVisibility(pm, scope, callingUid, callingPkg, targetPkg, userId, groupSticky);
++        } catch (RemoteException e) {
++            return true;
++        }
++    }
++
++    private static boolean shouldAllowVisibility(IPackageManager pm, AppsScope scope,
++            int callingUid, String callingPkg, String targetPkg, int userId) throws RemoteException {
++        return shouldAllowVisibility(pm, scope, callingUid, callingPkg, targetPkg, userId, true /* groupSticky */);
++    }
++
++    private static boolean shouldAllowVisibility(IPackageManager pm, AppsScope scope,
++            int callingUid, String callingPkg, String targetPkg, int userId, boolean groupSticky) throws RemoteException {
++        if (scope == null) return true;
++
++        if (callingPkg.equals(targetPkg)) {
++            return (scope.flags & FLAG_RESTRICT_SELF) == 0;
++        }
++
++        // We keep targetAi local here if groupSticky is true
++        ApplicationInfo resolvedAi = null;
++
++        if (groupSticky) {
++            // --- Target Group Resolution ---
++            final long identity = Binder.clearCallingIdentity();
++            try {
++                resolvedAi = pm.getApplicationInfo(targetPkg, 0, userId);
++            } catch (RemoteException ignored) {
++                // Should not happen for local system server calls
++            } finally {
++                Binder.restoreCallingIdentity(identity);
++            }
++
++            if (resolvedAi != null) {
++                // --- Group Sticky Logic ---
++                // If this package shares a UID with others, we must check the visibility of the ENTIRE group.
++                // If any package in the UID is denied, the whole group is denied.
++                String[] sharedPkgs = pm.getPackagesForUid(resolvedAi.uid);
++                if (sharedPkgs != null && sharedPkgs.length > 0) {
++                    for (String sibling : sharedPkgs) {
++                        ApplicationInfo siblingAi = sibling.equals(targetPkg) ? resolvedAi : null;
++                        if (!checkSinglePackageVisibility(pm, scope, callingUid, callingPkg, sibling, userId, siblingAi)) {
++                            return false; // A sibling is denied, so the whole group is denied
++                        }
++                    }
++                    return true;
++                }
++            }
++        }
++
++        return checkSinglePackageVisibility(pm, scope, callingUid, callingPkg, targetPkg, userId, resolvedAi);
++    }
++
++    private static boolean checkSinglePackageVisibility(IPackageManager pm, AppsScope scope,
++            int callingUid, String callingPkg, String targetPkg, int userId, @Nullable ApplicationInfo preResolvedAi) throws RemoteException {
++        // Check specific rules
++        Boolean specificRule = scope.specificRules.get(targetPkg);
++        if (specificRule != null) {
++            return specificRule.booleanValue();
++        }
++
++        // --- Category Restrictions ---
++        // We clear the calling identity to get the "truth" from the system,
++        // bypassing any visibility restrictions the caller might have.
++        ApplicationInfo targetAi = preResolvedAi;
++        if (targetAi == null) {
++            final long identity = Binder.clearCallingIdentity();
++            try {
++                targetAi = pm.getApplicationInfo(targetPkg, 0, userId);
++            } catch (RemoteException ignored) {
++                // Should not happen for local system server calls
++            } finally {
++                Binder.restoreCallingIdentity(identity);
++            }
++        }
++
++        if (targetAi == null) {
